<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="maintenance_tree" model="ir.ui.view">
        <field name="name">maintenance.tree</field>
        <field name="model">asset.maintenance</field>
        <field name="arch" type="xml">
            <tree string="Lịch sử bảo trì" decoration-info="state == 'draft'" decoration-success="state == 'done'">
                <field name="asset_id"/>
                <field name="maintenance_date"/>
                <field name="technician_id"/> <field name="maintenance_type" widget="badge" 
                       decoration-info="maintenance_type == 'inspection'" 
                       decoration-warning="maintenance_type == 'repair'"
                       decoration-success="maintenance_type == 'replacement'"/>
                <field name="degradation_level" string="Hao mòn (%)"/> <field name="cost" sum="Tổng chi phí"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'done'"/>
            </tree>
        </field>
    </record>

    <record id="maintenance_form" model="ir.ui.view">
        <field name="name">maintenance.form</field>
        <field name="model">asset.maintenance</field>
        <field name="arch" type="xml">
            <form string="Chi tiết bảo trì">
                <header>
                    <button name="action_done" string="Xác nhận hoàn thành" 
                            type="object" class="oe_highlight" 
                            attrs="{'invisible': [('state', '=', 'done')]}"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="asset_id" options="{'no_create': True}" placeholder="Chọn tài sản..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="Kỹ thuật &amp; Nhân sự">
                            <field name="maintenance_date" attrs="{'readonly': [('state', '=', 'done')]}"/>
                            <field name="technician_id" options="{'no_create': True}" attrs="{'readonly': [('state', '=', 'done')]}"/>
                            <field name="maintenance_type" attrs="{'readonly': [('state', '=', 'done')]}"/>
                        </group>
                        <group string="Tài chính &amp; AI">
                            <field name="cost" attrs="{'readonly': [('state', '=', 'done')]}"/>
                            <field name="degradation_level" attrs="{'readonly': [('state', '=', 'done')]}"/>
                            <field name="condition_after" attrs="{'readonly': [('state', '=', 'done')]}"/>
                            <field name="move_id" attrs="{'invisible': [('state', '!=', 'done')]}"/>
                        </group>
                    </group>
                    <group string="Ghi chú chi tiết">
                        <field name="note" nolabel="1" placeholder="Mô tả các linh kiện đã thay thế..."/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="maintenance_search" model="ir.ui.view">
        <field name="name">maintenance.search</field>
        <field name="model">asset.maintenance</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm bảo trì">
                <field name="asset_id"/>
                <field name="technician_id"/>
                <filter string="Mới (Dự thảo)" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Đã hoàn thành" name="done" domain="[('state', '=', 'done')]"/>
                <separator/>
                <group expand="0" string="Gom nhóm theo">
                    <filter string="Tài sản" name="group_by_asset" context="{'group_by':'asset_id'}"/>
                    <filter string="Kỹ thuật viên" name="group_by_tech" context="{'group_by':'technician_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="maintenance_action" model="ir.actions.act_window">
        <field name="name">Lịch sử bảo trì</field>
        <field name="res_model">asset.maintenance</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="maintenance_menu"
              name="Lịch sử bảo trì"
              parent="asset_root_menu"
              action="maintenance_action"
              sequence="20"/>
</odoo>