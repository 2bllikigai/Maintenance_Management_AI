<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="asset_search" model="ir.ui.view">
        <field name="name">asset.search</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm tài sản">
                <field name="name"/>
                <field name="category_id"/>
                <field name="employee_id"/>
                <separator/>
                <filter string="Cần bảo trì gấp" name="filter_warning" domain="[('maintenance_warning', '=', True)]"/>
                <filter string="Đang hỏng" name="filter_broken" domain="[('maintenance_status', '=', 'broken')]"/>
                <separator/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Danh mục" name="group_by_category" context="{'group_by': 'category_id'}"/>
                    <filter string="Trạng thái" name="group_by_status" context="{'group_by': 'maintenance_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="asset_tree" model="ir.ui.view">
        <field name="name">asset.tree</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <tree decoration-danger="maintenance_warning == True">
                <field name="name"/>
                <field name="category_id"/>
                <field name="employee_id"/>
                <field name="technician_id"/>
                <field name="original_value" sum="Tổng giá trị gốc"/>
                <field name="current_value" sum="Tổng giá trị hiện tại"/>
                <field name="predicted_next_maintenance" widget="remaining_days"/>
                <field name="maintenance_status" widget="badge" 
                       decoration-success="maintenance_status == 'ready'" 
                       decoration-warning="maintenance_status == 'maintaining'"
                       decoration-danger="maintenance_status == 'broken'"/>
                <field name="maintenance_warning" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="asset_form" model="ir.ui.view">
        <field name="name">asset.form</field>
        <field name="model">asset.asset</field>
        <field name="arch" type="xml">
            <form string="Tài sản">
                <header>
                    <button name="compute_depreciation_board" string="Tính kế hoạch khấu hao" type="object" class="oe_highlight" attrs="{'invisible': [('original_value', '&lt;=', 0)]}"/>
                    <field name="maintenance_status" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <field name="maintenance_warning" invisible="1"/>

                    <div class="alert alert-danger text-center o_form_header" role="alert" attrs="{'invisible': [('maintenance_warning', '=', False)]}">
                        <strong>Cảnh báo AI:</strong> Tài sản này sắp đến hạn bảo trì!
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Ví dụ: Laptop Dell XPS 15..."/></h1>
                    </div>
                    <group>
                        <group string="Quản lý &amp; Nhân sự">
                            <field name="category_id" options="{'no_create': True}"/>
                            <field name="employee_id" options="{'no_create_edit': True}"/>
                            <field name="technician_id" options="{'no_create_edit': True}"/>
                        </group>
                        <group string="Tài chính &amp; Kế toán">
                            <field name="original_value"/>
                            <field name="current_value" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Kế hoạch khấu hao">
                            <field name="depreciation_line_ids" readonly="1">
                                <tree>
                                    <field name="depreciation_date"/>
                                    <field name="amount" sum="Tổng khấu hao"/>
                                    <field name="remaining_value"/>
                                    <field name="is_posted" widget="boolean_toggle"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Lịch sử bảo trì">
                            <field name="maintenance_ids" context="{'default_asset_id': active_id}">
                                <tree editable="bottom">
                                    <field name="maintenance_date"/>
                                    <field name="maintenance_type"/>
                                    <field name="cost" sum="Tổng chi phí"/>
                                    <field name="state" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="asset_action" model="ir.actions.act_window">
        <field name="name">Tài sản doanh nghiệp</field>
        <field name="res_model">asset.asset</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="asset_search"/>
    </record>
</odoo>